# ==========================================
# NexTask - Variables de entorno de ejemplo
# Copiar este archivo como .env.local para desarrollo local.
# ==========================================

# Aplicación Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PORT=3000

# PostgreSQL usado por Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nex_task_dev
PG_PORT=5432

# URL de conexión para Prisma / capa server futura
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nex_task_dev?schema=public

# Autenticación futura
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-development

# Redis futuro
REDIS_URL=redis://localhost:6379
