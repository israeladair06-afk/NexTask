# ==========================================
# NexTask - Variables de entorno de ejemplo
# Copiar este archivo como .env para Docker Compose.
# Para desarrollo local directo sin Docker, copia a .env.local y ajusta los valores si hace falta.
# ==========================================

# Aplicación Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PORT=3000

# PostgreSQL usado por Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nex_task_dev
PG_PORT=5432

# URL de conexión para Prisma / capa server futura
# - En Docker Compose, usa host db: postgres://postgres:postgres@db:5432
# - En desarrollo local directo sin Docker, cambia localhost si corresponde.
DATABASE_URL=postgresql://postgres:postgres@db:5432/nex_task_dev?schema=public

# Autenticación futura
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-development

# Redis futuro
REDIS_URL=redis://localhost:6379
